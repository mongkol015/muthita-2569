              </button>
              <button class="qr-btn" id="qrPrint">
                <svg viewBox="0 0 24 24" fill="none"><path d="M6 9V3h12v6M6 18H4v-6h16v6h-2M8 14h8v7H8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
