<script>
  /* ---- scroll reveal ---- */
  (function(){
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window) || matchMedia('(prefers-reduced-motion: reduce)').matches){
      els.forEach(function(e){e.classList.add('show')});
      return;
    }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(en,i){
        if(en.isIntersecting){ en.target.classList.add('show'); io.unobserve(en.target);}
      });
    },{threshold:.12, rootMargin:'0px 0px -40px 0px'});
    els.forEach(function(e){io.observe(e)});
  })();

  /* ---- QR generator ---- */
  (function(){
    var toggle = document.getElementById('qrToggle');
    var panel  = document.getElementById('qrPanel');
    var holder = document.getElementById('qrcode');
    var input  = document.getElementById('qrUrl');
    var hint   = document.getElementById('qrHint');
    var qr = null, built = false, t;

    function currentUrl(){
      var u = window.location.href.split('#')[0];
      return u;
    }
    function isLocal(u){ return /^file:|^about:|localhost|127\.0\.0\.1/.test(u); }

    function render(text){
      holder.innerHTML = '';
      qr = new QRCode(holder, {
        text: text || ' ',
        width: 188, height: 188,
        colorDark:'#143b34', colorLight:'#ffffff',
        correctLevel: QRCode.CorrectLevel.M
      });
    }
    function updateHint(){
      var v = input.value.trim();
      if(!v){ hint.textContent=''; return; }
      if(isLocal(v)){
        hint.innerHTML = '⚠ ลิงก์นี้เป็นไฟล์ในเครื่อง สแกนจากมือถือเครื่องอื่นจะเปิดไม่ได้ — กรุณานำไฟล์ index.html ไปฝากไว้บนเว็บ (เช่น GitHub Pages, Netlify) แล้ววางลิงก์ที่ได้ตรงนี้';
      } else {
        hint.textContent = '✓ พร้อมใช้งาน — บันทึก QR แล้วนำไปใส่ในการ์ดเชิญหรือป้ายหน้างานได้เลย';
      }
    }
    function build(){
      if(built) return; built = true;
      var u = currentUrl();
      input.value = u;
      render(u);
      updateHint();
    }

    toggle.addEventListener('click', function(){
      var open = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true':'false');
      if(open){ build(); panel.scrollIntoView({behavior:'smooth', block:'nearest'}); }
    });

    input.addEventListener('input', function(){
      clearTimeout(t);
      t = setTimeout(function(){ render(input.value.trim()); updateHint(); }, 250);
    });

    document.getElementById('qrDownload').addEventListener('click', function(){
      var img = holder.querySelector('img');
      var canvas = holder.querySelector('canvas');
      var url = canvas ? canvas.toDataURL('image/png') : (img ? img.src : '');
      if(!url) return;
      var a = document.createElement('a');
      a.href = url; a.download = 'qr-มุทิตาจิต-19มิย2569.png';
      document.body.appendChild(a); a.click(); a.remove();
    });

    document.getElementById('qrPrint').addEventListener('click', function(){ window.print(); });
  })();
</script>
</body>
